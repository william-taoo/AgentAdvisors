# --- Required for local Postgres ---
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/agentadvisors

# --- Phase 1.3 ingestion: API keys (required only for enabled sources) ---

# NewsAPI (https://newsapi.org) — required if INGEST_ENABLE_NEWSAPI=true (default)
# Free developer tier: limited requests; paid plans for production search.
NEWSAPI_API_KEY=

# Finnhub (https://finnhub.io) — required if INGEST_ENABLE_FINNHUB=true (default)
FINNHUB_API_KEY=

# Pinecone — optional; only if INGEST_ENABLE_PINECONE=true
# Create an index with dimension 384 for the default embedding model (all-MiniLM-L6-v2).
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
# PINECONE_HOST is accepted as an alias for PINECONE_INDEX_HOST in code.
PINECONE_INDEX_NAME=agentadvisors-news

# --- Ingestion tuning (all optional) ---
INGEST_TICKERS=AAPL,MSFT,GOOGL
INGEST_YF_PERIOD=1mo
INGEST_NEWSAPI_PAGE_SIZE=20
INGEST_RSS_FEEDS=https://feeds.a.dj.com/rss/RSSMarketsMain.xml
INGEST_ENABLE_YFINANCE=true
INGEST_ENABLE_NEWSAPI=true
INGEST_ENABLE_RSS=true
INGEST_ENABLE_FINNHUB=true
INGEST_ENABLE_PINECONE=false
INGEST_ENABLE_USER_SCOPED_TARGETS=true
INGEST_MAX_RETRIES=3
INGEST_RETRY_BACKOFF=1.5
INGEST_HTTP_TIMEOUT=30
